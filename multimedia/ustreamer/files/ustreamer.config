
config ustreamer 'video0'
	option enabled '1'

	option device '/dev/video0'
	option device_timeout '5'
	option input '0'

#	option resolution '1920x1080'
#	option resolution '1280x720'
#	option resolution '800x600'
#	option resolution '864x480'
	option resolution '640x480'
#	option format 'YUYV'
	option quality '80'
	option desired_fps '0'
	option format 'MJPEG'
	option encoder 'HW'
#	option encoder 'CPU'
	option slowdown '1'
	option tcp_nodelay '0'

	option host '::'
	option port '8080'
	option static ''
	option user ''
	option password ''
